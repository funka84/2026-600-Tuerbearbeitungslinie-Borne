  <POU Name="FB_InfoConnection_1918_Logic" Id="{81dfb99c-c7fa-4346-a617-fbd8fc8a32c0}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_InfoConnection_1918_Logic
