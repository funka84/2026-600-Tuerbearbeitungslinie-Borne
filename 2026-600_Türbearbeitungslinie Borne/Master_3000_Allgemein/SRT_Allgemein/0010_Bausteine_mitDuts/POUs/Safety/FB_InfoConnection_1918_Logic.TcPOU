	bChannel3: BOOL;
	bChannel4: BOOL;
	bChannel5: BOOL;
	bChannel6: BOOL;
	bChannel7: BOOL;
	bChannel8: BOOL;
END_VAR
VAR
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[bChannel1 := stEL1918_Logic.inbyte_1.0; 
bChannel2 := stEL1918_Logic.inbyte_1.2; 
bChannel3 := stEL1918_Logic.inbyte_1.4; 
bChannel4 := stEL1918_Logic.inbyte_1.6; 
bChannel5 := stEL1918_Logic.inbyte_2.0; 
bChannel6 := stEL1918_Logic.inbyte_2.2; 
bChannel7 := stEL1918_Logic.inbyte_2.4; 
bChannel8 := stEL1918_Logic.inbyte_2.6; 

IF stEL1918_Logic.inbyte_1.1 THEN
